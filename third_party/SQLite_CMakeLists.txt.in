cmake_minimum_required(VERSION 3.25)
project(sqlite)

set(CMAKE_CXX_STANDARD 17)

include(ExternalProject)

if(WIN32)
    # Windows: Use CMake-based build for SQLite amalgamation
    ExternalProject_Add(
        sqlite_project
        URL "https://sqlite.org/2025/sqlite-autoconf-3510100.tar.gz"
        DOWNLOAD_EXTRACT_TIMESTAMP TRUE
        PREFIX "${CMAKE_BINARY_DIR}/third_party/sqlite"
        CONFIGURE_COMMAND "${CMAKE_COMMAND}" -G "${CMAKE_GENERATOR}"
            -DCMAKE_BUILD_TYPE=${CMAKE_BUILD_TYPE}
            "-DCMAKE_INSTALL_PREFIX=${CMAKE_BINARY_DIR}/third_party/sqlite/sqlite_project-install"
            "-DSQLITE_SOURCE_DIR=<SOURCE_DIR>"
            "-DCMAKE_MSVC_RUNTIME_LIBRARY=${CMAKE_MSVC_RUNTIME_LIBRARY}"
            -S "${CMAKE_SOURCE_DIR}/third_party/sqlite_cmake"
            -B <BINARY_DIR>
        BUILD_COMMAND "${CMAKE_COMMAND}" --build <BINARY_DIR> --config ${CMAKE_BUILD_TYPE}
        INSTALL_COMMAND "${CMAKE_COMMAND}" --install <BINARY_DIR> --config ${CMAKE_BUILD_TYPE}
    )
else()
    # Unix: Use autotools build
    ExternalProject_Add(
        sqlite_project
        URL "https://sqlite.org/2025/sqlite-autoconf-3510100.tar.gz"
        DOWNLOAD_EXTRACT_TIMESTAMP TRUE
        PREFIX "${CMAKE_BINARY_DIR}/third_party/sqlite"
        CONFIGURE_COMMAND ../sqlite_project/configure "CFLAGS=-DSQLITE_ENABLE_COLUMN_METADATA=1" --prefix=${CMAKE_BINARY_DIR}/third_party/sqlite/sqlite_project-install
        BUILD_COMMAND make
        INSTALL_COMMAND make install
    )
endif()
