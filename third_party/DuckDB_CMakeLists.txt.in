cmake_minimum_required(VERSION 3.25)
project(duckdb)

set(CMAKE_CXX_STANDARD 17)

include(ExternalProject)

ExternalProject_Add(
    duckdb_project
    PREFIX ${CMAKE_BINARY_DIR}/third_party
    GIT_REPOSITORY https://github.com/duckdb/duckdb
    GIT_TAG v1.5.1
    GIT_SHALLOW TRUE
    CMAKE_ARGS
          -DCMAKE_INSTALL_PREFIX=${CMAKE_BINARY_DIR}/third_party/duckdb
          -DCMAKE_C_COMPILER_LAUNCHER=${CMAKE_C_COMPILER_LAUNCHER}
          -DCMAKE_CXX_COMPILER_LAUNCHER=${CMAKE_CXX_COMPILER_LAUNCHER}
          "-DDUCKDB_EXTENSION_CONFIGS=${DUCKDB_EXTENSION_CONFIGS}"
          $<$<STREQUAL:${CMAKE_SYSTEM_NAME},iOS>:-DDISABLE_EXTENSION_LOAD=ON>
          $<$<STREQUAL:${CMAKE_SYSTEM_NAME},iOS>:-DGIZMOSQL_IOS=ON>
          $<$<BOOL:${WIN32}>:-DCMAKE_POLICY_DEFAULT_CMP0091=NEW>
          $<$<BOOL:${WIN32}>:-DCMAKE_MSVC_RUNTIME_LIBRARY=MultiThreaded$<$<CONFIG:Debug>:Debug>>
          $<$<BOOL:${WIN32}>:-DFORCE_STATIC_VCRT=ON>
)
