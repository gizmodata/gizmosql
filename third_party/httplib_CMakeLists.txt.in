cmake_minimum_required(VERSION 3.25)
project(cpp-httplib)

set(CMAKE_CXX_STANDARD 17)

include(ExternalProject)

# Forward OpenSSL hints from the outer CMake. The outer CMakeLists.txt
# computes @GIZMOSQL_HTTPLIB_OPENSSL_ARGS@ (a semicolon-separated list of
# -DFOO=bar pairs) based on its own cache variables. We pass them through
# as individual CMAKE_ARGS entries — configure_file() substitutes the
# outer value at generation time, so nothing depends on env-var
# inheritance surviving the nested ninja → cmake invocation chain.
set(_httplib_openssl_args "@GIZMOSQL_HTTPLIB_OPENSSL_ARGS@")

ExternalProject_Add(
    httplib_project
    PREFIX ${CMAKE_BINARY_DIR}/third_party
    GIT_REPOSITORY https://github.com/yhirose/cpp-httplib.git
    GIT_TAG v0.37.0
    GIT_SHALLOW TRUE
    CMAKE_ARGS
      -DCMAKE_INSTALL_PREFIX=${CMAKE_BINARY_DIR}/third_party/cpp-httplib
      -DHTTPLIB_REQUIRE_OPENSSL=ON
      ${_httplib_openssl_args}
    BUILD_COMMAND ""  # This is a header only library
)
