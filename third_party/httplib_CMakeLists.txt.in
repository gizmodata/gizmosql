cmake_minimum_required(VERSION 3.25)
project(cpp-httplib)

set(CMAKE_CXX_STANDARD 17)

include(ExternalProject)

ExternalProject_Add(
    httplib_project
    PREFIX ${CMAKE_BINARY_DIR}/third_party
    GIT_REPOSITORY https://github.com/yhirose/cpp-httplib.git
    GIT_TAG v0.37.0
    GIT_SHALLOW TRUE
    CMAKE_ARGS
      -DCMAKE_INSTALL_PREFIX=${CMAKE_BINARY_DIR}/third_party/cpp-httplib
      -DHTTPLIB_REQUIRE_OPENSSL=ON
      # Propagate OPENSSL_ROOT_DIR from the outer CMake (set by CI when the
      # runner's default search path doesn't include Homebrew's openssl@3).
      # The nested ExternalProject's CMake doesn't always inherit env vars
      # reliably through the ninja → cmake --build → cmake chain, so we
      # forward it explicitly. Also force static on macOS: Homebrew's
      # openssl@3 formula installs only static libs by default (libcrypto.a
      # / libssl.a) with no dylib symlinks, so FindOpenSSL's shared-lib
      # search fails unless we force static mode.
      -DOPENSSL_ROOT_DIR=$ENV{OPENSSL_ROOT_DIR}
      -DOPENSSL_USE_STATIC_LIBS=$ENV{OPENSSL_USE_STATIC_LIBS}
      -DOPENSSL_INCLUDE_DIR=$ENV{OPENSSL_INCLUDE_DIR}
      -DOPENSSL_CRYPTO_LIBRARY=$ENV{OPENSSL_CRYPTO_LIBRARY}
      -DOPENSSL_SSL_LIBRARY=$ENV{OPENSSL_SSL_LIBRARY}
    BUILD_COMMAND ""  # This is a header only library
)
