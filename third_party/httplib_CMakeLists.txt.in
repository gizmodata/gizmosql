cmake_minimum_required(VERSION 3.25)
project(cpp-httplib)

set(CMAKE_CXX_STANDARD 17)

include(ExternalProject)

# Forward OpenSSL hints from the outer environment into the nested
# ExternalProject CMake — but *only* when they are actually set. Passing
# them as empty strings (e.g. -DOPENSSL_ROOT_DIR=) clobbers the inner
# CMake's default search, which broke Linux (where none of these env
# vars are set). These are primarily set by the macOS CI step where
# Homebrew's openssl@3 is not on the default CMake search path.
set(_httplib_openssl_args "")
foreach(_var OPENSSL_ROOT_DIR OPENSSL_USE_STATIC_LIBS OPENSSL_INCLUDE_DIR
             OPENSSL_CRYPTO_LIBRARY OPENSSL_SSL_LIBRARY)
    if(DEFINED ENV{${_var}} AND NOT "$ENV{${_var}}" STREQUAL "")
        list(APPEND _httplib_openssl_args "-D${_var}=$ENV{${_var}}")
    endif()
endforeach()

ExternalProject_Add(
    httplib_project
    PREFIX ${CMAKE_BINARY_DIR}/third_party
    GIT_REPOSITORY https://github.com/yhirose/cpp-httplib.git
    GIT_TAG v0.37.0
    GIT_SHALLOW TRUE
    CMAKE_ARGS
      -DCMAKE_INSTALL_PREFIX=${CMAKE_BINARY_DIR}/third_party/cpp-httplib
      -DHTTPLIB_REQUIRE_OPENSSL=ON
      ${_httplib_openssl_args}
    BUILD_COMMAND ""  # This is a header only library
)
