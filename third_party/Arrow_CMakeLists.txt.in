cmake_minimum_required(VERSION 3.25)
project(arrow)

set(CMAKE_CXX_STANDARD 17)

include(ExternalProject)

# Arrow 23 has a macOS-specific bug where it tries to set_target_properties on
# c-ares::cares (an ALIAS target). This patch fixes it. On Linux, the pattern
# won't match (no if(APPLE) block executes), so the patch is harmless.

ExternalProject_Add(
    arrow_project
    PREFIX ${CMAKE_BINARY_DIR}/third_party
    GIT_REPOSITORY https://github.com/apache/arrow.git
    GIT_TAG apache-arrow-23.0.1
    SOURCE_SUBDIR cpp
    PATCH_COMMAND "${CMAKE_COMMAND}" -DARROW_SOURCE_DIR=<SOURCE_DIR> -P "${CMAKE_SOURCE_DIR}/third_party/patch_arrow.cmake"
    CMAKE_ARGS
      -DCMAKE_INSTALL_PREFIX=${CMAKE_BINARY_DIR}/third_party/arrow
      -DCMAKE_INSTALL_LIBDIR=lib
      -DCMAKE_INSTALL_INCLUDEDIR=include
      -DARROW_BUILD_TESTS=OFF
      -DARROW_BUILD_STATIC=ON
      -DARROW_BUILD_SHARED=OFF
      -DARROW_COMPUTE=ON
      -DARROW_CSV=ON
      -DARROW_JSON=ON
      -DARROW_DATASET=ON
      -DARROW_FILESYSTEM=ON
      -DARROW_FLIGHT=ON
      -DARROW_FLIGHT_SQL=ON
      -DARROW_DEPENDENCY_SOURCE=${ARROW_DEPENDENCY_SOURCE}
      -DARROW_DEPENDENCY_USE_SHARED=OFF
      ${ARROW_TOOLCHAIN_FILE_ARG}
      ${ARROW_VCPKG_TRIPLET_ARG}
      -Dxsimd_SOURCE=BUNDLED
      -DARROW_SIMD_LEVEL=${ARROW_SIMD_LEVEL}
      -DARROW_RUNTIME_SIMD_LEVEL=${ARROW_RUNTIME_SIMD_LEVEL}
      $<$<BOOL:${WIN32}>:-DARROW_USE_STATIC_CRT=ON>
)
